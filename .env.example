# Firebase Config
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:android:abc123

# Google Sign-In
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=123456789-xxxxx.apps.googleusercontent.com

# Midtrans (optional)
EXPO_PUBLIC_MIDTRANS_CLIENT_KEY=
EXPO_PUBLIC_MIDTRANS_SERVER_KEY=
EXPO_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# App Config
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_VERSION=2.0.0
EXPO_PUBLIC_MINING_SESSION_HOURS=6
EXPO_PUBLIC_KYC_MINING_DAYS_REQUIRED=10
